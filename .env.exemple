GOOGLE_GENERATIVE_AI_API_KEY=sua_chave_gemini_aqui
AI_MODEL=gemini-flash-lite-latest
ALLOWED_ORIGINS=http://localhost:3000
# Gere um valor seguro com: openssl rand -hex 32
SESSION_TOKEN_SECRET=SUBSTITUA_POR_UM_VALOR_GERADO_COM_openssl_rand_hex_32
SESSION_TOKEN_EXPIRY_MINUTES=5

# Variáveis do Upstash/Vercel KV locais (Simulado via Docker Compose SRH)
KV_REST_API_URL=http://localhost:8079
KV_REST_API_TOKEN=token_local_dev
UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=token_local_dev
